# ────────────────────────────────────────────────────────
# HireUp FastAPI — Production environment template
# Copy to .env.production and replace every <CHANGE_ME>.
# NEVER commit the real .env.production file.
# ────────────────────────────────────────────────────────

APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# Hostnames Nginx / load balancer will pass through (comma-separated)
TRUSTED_HOSTS=api.hireup.uz

# Frontend origins allowed by CORS (comma-separated, no wildcard in prod)
CORS_ORIGINS=https://hireup.uz,https://www.hireup.uz

# ── PostgreSQL ────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=hireup
POSTGRES_PASSWORD=<CHANGE_ME_strong_password>
POSTGRES_DB=hireup

# Tune to roughly match CPU + connection budget
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE_SECONDS=1800
DB_STATEMENT_TIMEOUT_MS=15000

# ── Auth ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET=<CHANGE_ME_64_random_hex_chars>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# bcrypt cost — 12 is the production default
BCRYPT_ROUNDS=12

# ── Uploads ───────────────────────────────────────────
UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=5242880
BODY_MAX_BYTES=10485760
GZIP_MINIMUM_SIZE=1024

# ── Rate limiting (production = stricter) ─────────────
RATE_LIMIT_PER_MINUTE=100
LOGIN_RATE_LIMIT=5/minute
REGISTER_RATE_LIMIT=3/minute
REFRESH_RATE_LIMIT=20/minute

# ── Gunicorn ──────────────────────────────────────────
# Default: cpu_count * 2 + 1. Override if you need a tighter cap.
# GUNICORN_WORKERS=4

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO

DEFAULT_LANGUAGE=uz
