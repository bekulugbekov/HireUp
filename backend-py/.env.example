# ───────────────────────────────────────────────
# HireUp FastAPI Backend — Environment Variables
# ───────────────────────────────────────────────

# Application
APP_NAME=HireUp
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS — comma-separated list
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Trusted Host header values — comma-separated, "*" for development
TRUSTED_HOSTS=["*"]

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hireup
POSTGRES_PASSWORD=hireup_dev_password
POSTGRES_DB=hireup
# Full URL alternative (overrides individual fields if set):
# DATABASE_URL=postgresql+asyncpg://hireup:hireup_dev_password@localhost:5432/hireup

# Database connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800
DB_STATEMENT_TIMEOUT_MS=10000

# JWT
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Bcrypt
BCRYPT_ROUNDS=12

# Uploads
UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=5242880

# Request body hard cap (separate from upload-specific limit)
BODY_MAX_BYTES=10485760

# GZip compression — responses smaller than this are not compressed
GZIP_MINIMUM_SIZE=1024

# Rate limiting
RATE_LIMIT_PER_MINUTE=100
LOGIN_RATE_LIMIT=10/minute
REGISTER_RATE_LIMIT=5/minute
REFRESH_RATE_LIMIT=30/minute

# Logging
LOG_LEVEL=INFO

# Default i18n language when Accept-Language is missing
DEFAULT_LANGUAGE=uz
